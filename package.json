{
  "name": "uisketch-workspace",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:web": "npm run build -w @uisketch/web",
    "build:desktop-assets": "sh scripts/build-wails-frontend.sh",
    "dev:web": "npm run dev -w @uisketch/web",
    "preview:web": "npm run preview -w @uisketch/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^5.1.4",
    "daisyui": "^5.5.23",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "vite": "^7.0.0"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  }
}
